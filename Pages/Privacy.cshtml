@page
@model PrivacyModel
@{
    ViewData["Title"] = "Privacy Policy";
}

<section class="max-w-3xl mx-auto">
    <div class="glass glass-highlight rounded-3xl p-8 sm:p-10">
        <h1 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">@ViewData["Title"]</h1>
        <p class="text-white/80 leading-relaxed">
            Use this page to detail your site's privacy policy.
        </p>
    </div>
</section>
