@page
@model QueryModel
@{
    ViewData["Title"] = "Submit a query";
}

<section class="max-w-2xl mx-auto">
    <div class="text-center mb-8">
        <h1 class="text-4xl sm:text-5xl font-bold tracking-tight mb-3">Get in touch</h1>
        <p class="text-lg text-white/75">
            Have a question about our rooftop kits, dashboard, or harvest program?
            Send us a query and we'll get back to you.
        </p>
    </div>

    @if (Model.SuccessMessage is not null)
    {
        <div class="alert-success mb-5" role="alert">@Model.SuccessMessage</div>
    }

    @if (Model.ErrorMessage is not null)
    {
        <div class="alert-danger mb-5" role="alert">@Model.ErrorMessage</div>
    }

    <form method="post" class="glass-strong glass-highlight rounded-3xl p-6 sm:p-8 space-y-5">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div>
            <label asp-for="Input.Name" class="label-glass"></label>
            <input asp-for="Input.Name" class="input-glass" autocomplete="name" />
            <span asp-validation-for="Input.Name" class="text-danger"></span>
        </div>

        <div>
            <label asp-for="Input.Email" class="label-glass"></label>
            <input asp-for="Input.Email" class="input-glass" autocomplete="email" />
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>

        <div>
            <label asp-for="Input.Subject" class="label-glass"></label>
            <input asp-for="Input.Subject" class="input-glass" />
            <span asp-validation-for="Input.Subject" class="text-danger"></span>
        </div>

        <div>
            <label asp-for="Input.Message" class="label-glass"></label>
            <textarea asp-for="Input.Message" class="input-glass resize-y" rows="6"></textarea>
            <span asp-validation-for="Input.Message" class="text-danger"></span>
        </div>

        <div class="pt-2">
            <button type="submit" class="btn-primary w-full sm:w-auto">Send query</button>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
