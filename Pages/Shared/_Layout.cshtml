@inject IConfiguration Config
@{
    var pageTitle = ViewData["Title"];
    var supabaseUrl = Config["Supabase:Url"] ?? "";
    var supabaseKey = Config["Supabase:Key"] ?? "";
}
<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - Verdant Labs</title>
    <meta name="theme-color" content="#0e2360" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@@400;500;600;700&display=swap" rel="stylesheet" />

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'ui-sans-serif', 'system-ui', '-apple-system', 'BlinkMacSystemFont', 'Segoe UI', 'sans-serif']
                    },
                    colors: {
                        ocean: {
                            50:  '#eef6ff',
                            100: '#d9eaff',
                            200: '#b8d6ff',
                            300: '#8bbcff',
                            400: '#5b97ff',
                            500: '#3776ff',
                            600: '#1f57f0',
                            700: '#1a44c5',
                            800: '#19389a',
                            900: '#0e2360',
                            950: '#08153a'
                        }
                    }
                }
            }
        };
    </script>

    <style type="text/tailwindcss">
        @@layer components {
            .glass {
                background: linear-gradient(135deg, rgba(255,255,255,0.18) 0%, rgba(255,255,255,0.08) 100%);
                -webkit-backdrop-filter: blur(28px) saturate(180%);
                backdrop-filter: blur(28px) saturate(180%);
                border: 1px solid rgba(255,255,255,0.22);
                box-shadow: 0 8px 32px rgba(8,21,58,0.35), inset 0 1px 0 rgba(255,255,255,0.35);
            }
            .glass-strong {
                background: linear-gradient(135deg, rgba(255,255,255,0.28) 0%, rgba(255,255,255,0.14) 100%);
                -webkit-backdrop-filter: blur(36px) saturate(200%);
                backdrop-filter: blur(36px) saturate(200%);
                border: 1px solid rgba(255,255,255,0.28);
                box-shadow: 0 12px 40px rgba(8,21,58,0.40), inset 0 1px 0 rgba(255,255,255,0.45);
            }
            .glass-highlight { @@apply relative overflow-hidden; }
            .glass-highlight::before {
                content: '';
                position: absolute;
                inset: 0;
                pointer-events: none;
                background: radial-gradient(1200px circle at top right, rgba(255,255,255,0.20), transparent 40%);
            }
            .nav-pill {
                @@apply inline-block rounded-full px-4 py-1.5 text-white/80 hover:text-white hover:bg-white/10 transition-colors;
            }
            .nav-pill-active { @@apply text-white bg-white/15; }
            .btn-primary {
                @@apply inline-flex items-center justify-center px-6 py-3 rounded-full font-medium text-white
                       bg-gradient-to-br from-ocean-400 to-ocean-600
                       border border-white/30
                       hover:from-ocean-300 hover:to-ocean-500
                       active:scale-[0.98] transition;
                box-shadow: 0 8px 24px rgba(31,87,240,0.45), inset 0 1px 0 rgba(255,255,255,0.4);
            }
            .btn-ghost {
                @@apply inline-flex items-center justify-center px-5 py-2.5 rounded-full font-medium
                       text-white border border-white/30 bg-white/10 hover:bg-white/20 active:scale-[0.98] transition;
            }
            .input-glass {
                @@apply w-full rounded-2xl bg-white/15 border border-white/25 px-4 py-3 text-white placeholder-white/50
                       focus:outline-none focus:border-ocean-300 focus:bg-white/20
                       focus:ring-2 focus:ring-ocean-300/40 transition;
                -webkit-backdrop-filter: blur(14px);
                backdrop-filter: blur(14px);
            }
            .label-glass { @@apply block text-sm font-medium text-white/85 mb-2; }
            .alert-success {
                @@apply rounded-2xl px-4 py-3 text-emerald-50 border border-emerald-300/40;
                background: linear-gradient(135deg, rgba(16,185,129,0.30), rgba(16,185,129,0.15));
                -webkit-backdrop-filter: blur(20px);
                backdrop-filter: blur(20px);
            }
            .alert-danger {
                @@apply rounded-2xl px-4 py-3 text-rose-50 border border-rose-300/40;
                background: linear-gradient(135deg, rgba(244,63,94,0.30), rgba(244,63,94,0.15));
                -webkit-backdrop-filter: blur(20px);
                backdrop-filter: blur(20px);
            }
        }

        /* Validation message styling (rendered by ASP.NET tag helpers) */
        .field-validation-error,
        .text-danger {
            color: #fda4af; /* rose-300 */
            font-size: 0.875rem;
            display: block;
            margin-top: 0.375rem;
        }
        .input-validation-error {
            border-color: rgba(253,164,175,0.7) !important;
            background-color: rgba(253,164,175,0.10) !important;
        }

        /* Floating blurred orbs for depth */
        .orb {
            position: absolute;
            border-radius: 9999px;
            filter: blur(90px);
            opacity: 0.40;
            will-change: transform;
        }
        .orb-1 { width: 520px; height: 520px; background: #3776ff; top: -120px;  left: -120px; animation: float-1 18s ease-in-out infinite; }
        .orb-2 { width: 420px; height: 420px; background: #1a44c5; top: 30%;     right: -160px; animation: float-2 22s ease-in-out infinite; }
        .orb-3 { width: 360px; height: 360px; background: #5b97ff; bottom: -120px; left: 35%;   animation: float-3 26s ease-in-out infinite; }
        @@keyframes float-1 { 0%,100% { transform: translate(0,0); } 50% { transform: translate(80px,60px); } }
        @@keyframes float-2 { 0%,100% { transform: translate(0,0); } 50% { transform: translate(-60px,40px); } }
        @@keyframes float-3 { 0%,100% { transform: translate(0,0); } 50% { transform: translate(40px,-50px); } }
        @@media (prefers-reduced-motion: reduce) { .orb { animation: none; } }
    </style>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="min-h-screen font-sans text-white antialiased relative overflow-x-hidden bg-gradient-to-br from-[#020617] via-ocean-950 to-ocean-800">

    <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>
    </div>

    <header class="sticky top-4 z-40 px-4">
        <nav class="glass mx-auto max-w-6xl flex items-center justify-between px-5 py-3 rounded-full">
            <a class="font-semibold text-lg tracking-tight flex items-center gap-2" asp-area="" asp-page="/Index">
                <span class="text-xl">🌿</span>
                <span>Verdant Labs</span>
            </a>
            <ul class="flex items-center gap-1 text-sm">
                <li><a class="nav-pill" asp-area="" asp-page="/Index">Home</a></li>
                <li><a class="nav-pill" asp-area="" asp-page="/Objects">Objects</a></li>
                <li><a class="nav-pill" asp-area="" asp-page="/Query">Contact</a></li>
                <li class="hidden sm:list-item"><a class="nav-pill" asp-area="" asp-page="/Privacy">Privacy</a></li>
                <li id="auth-slot" class="ml-2 pl-3 border-l border-white/15 flex items-center gap-2">
                    <span class="text-white/50 text-xs">&hellip;</span>
                </li>
            </ul>
        </nav>
    </header>

    <main class="mx-auto max-w-6xl px-4 pt-10 pb-24">
        @RenderBody()
    </main>

    <footer class="text-center text-white/60 text-sm pb-8">
        &copy; 2026 Verdant Labs &middot;
        <a asp-area="" asp-page="/Privacy" class="hover:text-white underline-offset-4 hover:underline">Privacy</a>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@supabase/supabase-js@@2"></script>
    <script>
        (function () {
            const SUPABASE_URL = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(supabaseUrl));
            const SUPABASE_KEY = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(supabaseKey));

            if (!SUPABASE_URL || !SUPABASE_KEY) {
                console.warn('Supabase config missing — auth disabled.');
                document.getElementById('auth-slot').innerHTML = '';
                return;
            }

            const supabase = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY, {
                auth: { persistSession: true, autoRefreshToken: true, detectSessionInUrl: true }
            });
            window._supabase = supabase;

            function escapeHtml(s) {
                const d = document.createElement('div');
                d.textContent = s == null ? '' : String(s);
                return d.innerHTML;
            }

            function render(session) {
                const slot = document.getElementById('auth-slot');
                if (!slot) return;
                if (session && session.user) {
                    const u = session.user;
                    const name = (u.user_metadata && (u.user_metadata.full_name || u.user_metadata.name)) || u.email || 'Signed in';
                    slot.innerHTML =
                        '<span class="hidden sm:inline text-white/80 max-w-[10rem] truncate">' + escapeHtml(name) + '</span>' +
                        '<button type="button" class="nav-pill" data-sb-action="signout">Sign out</button>';
                } else {
                    slot.innerHTML =
                        '<button type="button" class="nav-pill inline-flex items-center gap-2" data-sb-action="signin">' +
                          '<svg class="w-4 h-4" viewBox="0 0 48 48" aria-hidden="true">' +
                            '<path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>' +
                            '<path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>' +
                            '<path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>' +
                            '<path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>' +
                          '</svg>' +
                          '<span>Sign in</span>' +
                        '</button>';
                }
            }

            document.addEventListener('click', async function (e) {
                const btn = e.target.closest('[data-sb-action]');
                if (!btn) return;
                const action = btn.dataset.sbAction;
                if (action === 'signin') {
                    await supabase.auth.signInWithOAuth({
                        provider: 'google',
                        options: { redirectTo: window.location.origin + window.location.pathname }
                    });
                } else if (action === 'signout') {
                    await supabase.auth.signOut();
                    location.reload();
                }
            });

            // Initial render + react to auth state changes.
            supabase.auth.getSession().then(function (res) { render(res.data.session); });
            supabase.auth.onAuthStateChange(function (_event, session) { render(session); });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
